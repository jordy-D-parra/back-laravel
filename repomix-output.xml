.pagination-btn:hover:not(.disabled):not(.active) {
    background: #1e3c72;
    color: #ffffff;
    border-color: #1e3c72;
}

.pagination-btn.active {
    background: #1e3c72;
    color: #ffffff;
    border-color: #1e3c72;
    font-weight: 600;
}

.pagination-btn.disabled {
    opacity: 0.4;
    cursor: not-allowed;
}

.pagination-ellipsis {
    width: 34px;
    height: 34px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #6c757d;
}

/* Botones oscuros */
.btn-primary-dark,
.btn-primary-dark:hover,
