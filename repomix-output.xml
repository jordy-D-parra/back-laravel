/* ========================================
   ESTILOS DEL MÓDULO DE INVENTARIO
   ======================================== */

/* === Encabezado y botones === */
.btn-primary-dark {
    background: linear-gradient(135deg, #1e3c72 0%, #2a5298 100%);
    color: #ffffff;
    border: none;
    font-weight: 500;
    transition: all 0.3s ease;
}

.btn-primary-dark:hover {
    background: linear-gradient(135deg, #152a50 0%, #1e3c72 100%);
    color: #ffffff;
    transform: translateY(-1px);
    box-shadow: 0 4px 12px rgba(30, 60, 114, 0.3);
}

.btn-outline-primary-dark {
    background: transparent;
    color: #1e3c72;
    border: 1px solid #1e3c72;
    font-weight: 500;
    transition: all 0.3s ease;
}

.btn-outline-primary-dark:hover {
    background: #1e3c72;
    color: #ffffff;
}

/* === Tarjetas de estadísticas === */
.stats-row {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
}

.stat-card-mini {
    background: #ffffff;
    border-radius: 10px;
    padding: 1.25rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
    border-left: 4px solid #1e3c72;
    transition: all 0.3s ease;
}

.stat-card-mini:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.1);
}

.stat-card-mini .stat-number {
    font-size: 1.75rem;
    font-weight: 700;
    color: #1e3c72;
    line-height: 1.2;
}

.stat-card-mini .stat-label {
    font-size: 0.8rem;
    color: #6c757d;
    text-transform: uppercase;
    letter-spacing: 0.5px;
}

.stat-icon-circle {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: rgba(30, 60, 114, 0.1);
    display: flex;
    align-items: center;
    justify-content: center;
    color: #1e3c72;
}

/* === Navegación por tabs === */
.nav-tabs-custom {
    border-bottom: 2px solid #e9ecef;
    gap: 0.25rem;
}

.nav-tabs-custom .nav-link {
    border: none;
    color: #6c757d;
    font-weight: 500;
    padding: 0.75rem 1.25rem;
    border-radius: 8px 8px 0 0;
    transition: all 0.2s ease;
    position: relative;
}

.nav-tabs-custom .nav-link:hover {
    color: #1e3c72;
    background: rgba(30, 60, 114, 0.05);
}

.nav-tabs-custom .nav-link.active {
    color: #1e3c72;
    background: transparent;
    font-weight: 600;
}

.nav-tabs-custom .nav-link.active::after {
    content: '';
    position: absolute;
    bottom: -2px;
    left: 0;
    right: 0;
    height: 3px;
    background: linear-gradient(135deg, #1e3c72 0%, #2a5298 100%);
    border-radius: 3px 3px 0 0;
}

.tab-badge {
    background: rgba(30, 60, 114, 0.1);
    color: #1e3c72;
    font-size: 0.75rem;
    padding: 2px 8px;
    border-radius: 12px;
    margin-left: 6px;
}

/* === Barra de filtros === */
.filters-bar {
    display: flex;
    gap: 0.75rem;
    align-items: center;
    flex-wrap: wrap;
}

.filters-bar .flex-grow-1 {
    flex: 1;
    min-width: 200px;
}

.filters-bar .form-control,
.filters-bar .form-select {
    border: 1px solid #dee2e6;
    border-radius: 8px;
    padding: 0.5rem 0.75rem;
    font-size: 0.875rem;
    transition: all 0.2s ease;
}

.filters-bar .form-control:focus,
.filters-bar .form-select:focus {
    border-color: #1e3c72;
    box-shadow: 0 0 0 0.2rem rgba(30, 60, 114, 0.15);
}

/* === Tabla === */
.table-container {
    background: #ffffff;
    border-radius: 10px;
    overflow: hidden;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
}

.table-container table {
    margin-bottom: 0;
}

.table-container thead th {
    background: #f8f9fa;
    color: #1e3c72;
    font-weight: 600;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    border-bottom: 2px solid #dee2e6;
    padding: 0.75rem 1rem;
    white-space: nowrap;
}

.table-container tbody td {
    padding: 0.75rem 1rem;
    vertical-align: middle;
    font-size: 0.875rem;
    border-bottom: 1px solid #f0f0f0;
}

.table-container tbody tr:hover {
    background: rgba(30, 60, 114, 0.02);
}

/* === Badges de estado === */
.badge-estatus {
    display: inline-block;
    padding: 4px 10px;
    border-radius: 6px;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.3px;
}

.badge-success { background: #d4edda; color: #155724; }
.badge-warning { background: #fff3cd; color: #856404; }
.badge-info { background: #d1ecf1; color: #0c5460; }
.badge-danger { background: #f8d7da; color: #721c24; }
.badge-secondary { background: #e2e3e5; color: #383d41; }
.badge-primary { background: #cce5ff; color: #004085; }

/* === Botones de acción === */
.btn-action {
    padding: 0.35rem 0.6rem;
    border-radius: 6px;
    border: none;
    cursor: pointer;
    transition: all 0.2s ease;
    background: transparent;
    color: #6c757d;
}

.btn-action:hover {
    background: #f0f0f0;
    color: #1e3c72;
}

.btn-action.text-danger:hover {
    background: #fee2e2;
    color: #dc3545;
}

/* === Modal === */
.modal-header.bg-primary-dark {
    border-radius: 7px 7px 0 0;
}

.modal-content {
    border: none;
    border-radius: 10px;
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.15);
}

.modal-body .form-label {
    font-weight: 500;
    font-size: 0.85rem;
    color: #333;
    margin-bottom: 0.3rem;
}

.modal-body .form-control,
.modal-body .form-select {
    border-radius: 8px;
    border: 1px solid #dee2e6;
    padding: 0.5rem 0.75rem;
    font-size: 0.875rem;
}

.modal-body .form-control:focus,
.modal-body .form-select:focus {
    border-color: #1e3c72;
    box-shadow: 0 0 0 0.2rem rgba(30, 60, 114, 0.15);
}

/* === Toast === */
.toast-container {
    position: fixed;
    top: 20px;
    right: 20px;
    z-index: 9999;
}

.toast-custom {
    background: #ffffff;
    border-radius: 10px;
    padding: 1rem 1.25rem;
    margin-bottom: 0.5rem;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.15);
    display: flex;
    align-items: center;
    gap: 0.75rem;
    min-width: 300px;
    animation: slideIn 0.3s ease;
}

.toast-custom.success { border-left: 4px solid #28a745; }
.toast-custom.error { border-left: 4px solid #dc3545; }
.toast-custom.warning { border-left: 4px solid #ffc107; }
.toast-custom.info { border-left: 4px solid #17a2b8; }

@keyframes slideIn {
    from { transform: translateX(100%); opacity: 0; }
    to { transform: translateX(0); opacity: 1; }
}

/* === Detalle modal === */
.detalle-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.75rem;
}

.detalle-item {
    display: flex;
    flex-direction: column;
}

.detalle-item .label {
    font-size: 0.75rem;
    color: #6c757d;
    text-transform: uppercase;
    letter-spacing: 0.5px;
}

.detalle-item .value {
    font-size: 0.9rem;
    color: #1a1a1a;
    font-weight: 500;
}

/* === Responsive === */
@media (max-width: 992px) {
    .stats-row {
        grid-template-columns: repeat(2, 1fr);
    }

    .filters-bar {
        flex-direction: column;
    }

    .filters-bar .form-control,
    .filters-bar .form-select,
    .filters-bar .flex-grow-1 {
        width: 100%;
    }
}

@media (max-width: 576px) {
    .stats-row {
        grid-template-columns: 1fr;
    }
}

/* Corregir texto blanco en botones oscuros */
.btn-primary-dark,
.btn-primary-dark:hover,
.btn-primary-dark:focus,
.btn-primary-dark:active,
.btn-primary-dark:visited {
    color: #ffffff !important;
}

.btn-outline-primary-dark {
    color: #1e3c72;
    background: transparent;
