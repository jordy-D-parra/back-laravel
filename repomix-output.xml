<?php

namespace Database\Seeders;

use App\Models\Activo;
use App\Models\Componente;
use App\Models\Departamento;
use App\Models\Institucion;
use App\Models\Prestamo;
use App\Models\PrestamoDetalle;
use App\Models\Responsable;
use App\Models\Solicitud;
use App\Models\DetalleSolicitud;
use App\Models\Usuario;
use Illuminate\Database\Seeder;
use Illuminate\Support\Facades\DB;

class SolicitudPrestamoDemoSeeder extends Seeder
{
    public function run(): void
    {
        $this->command->info('Creando solicitudes y préstamos de prueba...');

        $usuario = Usuario::query()->where('usuario', 'jordy')->first() ?? Usuario::query()->first();
        $departamento = Departamento::query()->first();
        $institucion = Institucion::query()->first();
        $responsable = Responsable::query()->where('activo', true)->first();

        if (! $usuario || ! $responsable) {
            $this->command->error('Faltan datos base para crear solicitudes y préstamos.');
            return;
        }

        $plantillas = [
            [
                'justificacion' => 'Solicitud de prueba para equipo de oficina en el área administrativa.',
                'prioridad' => 'alta',
                'estado_solicitud' => 'aprobada',
                'tipo_solicitante' => 'interno',
                'departamento_id' => $departamento?->id,
                'institucion_id' => null,
                'responsable_id' => $responsable->id,
            ],
            [
                'justificacion' => 'Solicitud de prueba para laboratorio con componentes complementarios.',
                'prioridad' => 'normal',
                'estado_solicitud' => 'aprobada',
                'tipo_solicitante' => 'externo',
                'departamento_id' => null,
                'institucion_id' => $institucion?->id,
                'responsable_id' => $responsable->id,
            ],
            [
                'justificacion' => 'Solicitud de prueba pendiente para validar el flujo de aprobación.',
                'prioridad' => 'baja',
                'estado_solicitud' => 'pendiente',
                'tipo_solicitante' => 'interno',
                'departamento_id' => $departamento?->id,
                'institucion_id' => null,
                'responsable_id' => $responsable->id,
            ],
        ];

        $solicitudes = [];

        foreach ($plantillas as $index => $plantilla) {
            $solicitud = Solicitud::query()->create([
                'usuario_id' => $usuario->id,
                'tipo_solicitante' => $plantilla['tipo_solicitante'],
                'institucion_id' => $plantilla['institucion_id'],
                'departamento_id' => $plantilla['departamento_id'],
                'responsable_id' => $plantilla['responsable_id'],
                'fecha_solicitud' => now()->subDays($index + 1),
                'fecha_requerida' => now()->addDays($index + 3),
                'fecha_fin_estimada' => now()->addDays($index + 10),
                'justificacion' => $plantilla['justificacion'],
                'prioridad' => $plantilla['prioridad'],
                'estado_solicitud' => $plantilla['estado_solicitud'],
                'observaciones' => 'Generada automáticamente para pruebas de préstamos.',
            ]);

            $solicitudes[] = $solicitud;

            $activoDisponible = Activo::query()->whereHas('estatus', fn ($q) => $q->where('permite_prestamo', true))->first();
            $componenteDisponible = Componente::query()->where('estado', 'en_bodega')->first();

            if ($activoDisponible) {
                DetalleSolicitud::query()->create([
                    'solicitud_id' => $solicitud->id,
                    'activo_id' => $activoDisponible->id,
                    'tipo_item' => 'activo',
                    'cantidad_solicitada' => 1,
                    'observaciones' => 'Item de prueba',
                ]);
            }

            if ($componenteDisponible) {
                DetalleSolicitud::query()->create([
                    'solicitud_id' => $solicitud->id,
                    'componente_id' => $componenteDisponible->id,
                    'tipo_item' => 'componente',
                    'cantidad_solicitada' => 1,
                    'observaciones' => 'Componente de prueba',
                ]);
            }
        }

        $this->crearPrestamo($solicitudes[0], 'aprobado', $responsable);
        $this->crearPrestamo($solicitudes[1], 'entregado', $responsable);
        $this->crearPrestamo(null, 'devuelto', $responsable);

        $this->command->info('✅ Solicitudes y préstamos de prueba creados correctamente.');
    }

    private function crearPrestamo(?Solicitud $solicitud, string $estado, Responsable $responsable): void
    {
        $activoDisponible = Activo::query()->whereHas('estatus', fn ($q) => $q->where('permite_prestamo', true))->first();
        $componenteDisponible = Componente::query()->where('estado', 'en_bodega')->first();

        if (! $activoDisponible && ! $componenteDisponible) {
            return;
        }

        $prestamo = Prestamo::query()->create([
            'codigo' => Prestamo::generarCodigo(),
            'tipo_prestamo' => $activoDisponible && $componenteDisponible ? 'mixto' : ($activoDisponible ? 'equipo' : 'componente'),
            'estado' => $estado,
            'departamento_id' => $solicitud?->departamento_id,
            'institucion_id' => $solicitud?->institucion_id,
            'responsable_receptor_id' => $responsable->id,
            'responsable_emisor_id' => $responsable->id,
            'usuario_registra_id' => Usuario::query()->where('usuario', 'jordy')->first()?->id ?? Usuario::query()->first()?->id,
            'fecha_prestamo' => now()->subDays(2),
            'fecha_devolucion_esperada' => now()->addDays(7),
            'fecha_devolucion_real' => $estado === 'devuelto' ? now()->subDay() : null,
            'observaciones' => 'Préstamo generado por el seeder de pruebas.',
            'solicitud_id' => $solicitud?->id,
        ]);

        if ($activoDisponible) {
            PrestamoDetalle::query()->create([
                'prestamo_id' => $prestamo->id,
                'prestable_type' => Activo::class,
                'prestable_id' => $activoDisponible->id,
                'cantidad' => 1,
                'estado_entrega' => $estado === 'devuelto' ? 'devuelto' : 'entregado',
                'observaciones' => 'Detalle de prueba',
            ]);

            if (in_array($estado, ['aprobado', 'entregado'], true)) {
                $activoDisponible->marcarComoPrestado();
            } else {
                $activoDisponible->marcarComoDisponible();
            }
        }

        if ($componenteDisponible) {
            PrestamoDetalle::query()->create([
                'prestamo_id' => $prestamo->id,
                'prestable_type' => Componente::class,
                'prestable_id' => $componenteDisponible->id,
                'cantidad' => 1,
                'estado_entrega' => $estado === 'devuelto' ? 'devuelto' : 'entregado',
                'observaciones' => 'Detalle de prueba',
            ]);

            if (in_array($estado, ['aprobado', 'entregado'], true)) {
                $componenteDisponible->marcarComoPrestado();
            } else {
                $componenteDisponible->marcarComoDevuelto();
            }
        }

        if ($solicitud) {
            $solicitud->update([
                'estado_solicitud' => $estado === 'devuelto' ? 'entregada' : ($estado === 'entregado' ? 'entregada' : 'aprobada'),
            ]);
        }
    }
}
