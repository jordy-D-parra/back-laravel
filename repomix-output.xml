    border: none;
    background: transparent;
    padding: 12px 24px;
    font-weight: 600;
    color: #6c757d;
    border-radius: 8px 8px 0 0;
    transition: all 0.2s ease;
    display: flex;
    align-items: center;
    gap: 8px;
