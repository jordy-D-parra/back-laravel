    color: #1a1a1a;
}

.dropdown-item:hover {
    background: #1e3c72;
    color: #ffffff !important;
}

/* Paginación */
.pagination-bar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.75rem 0;
    flex-wrap: wrap;
    gap: 0.5rem;
