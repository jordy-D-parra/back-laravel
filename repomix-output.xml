/* ============================================================
   Panel de Entidades Unificado - CSS Profesional
   ============================================================ */

/* ---------- Variables ---------- */
:root {
    --primary-dark: #1e3c72;
    --primary-light: #2a4a8a;
    --primary-lighter: #eef3fc;
    --success: #1e7e34;
    --danger: #c5221f;
    --warning: #f6c23e;
    --gray-bg: #f8f9fc;
    --border-light: #e9ecef;
    --text-muted: #6c757d;
    --shadow-sm: 0 2px 8px rgba(0, 0, 0, 0.05);
    --shadow-md: 0 4px 12px rgba(0, 0, 0, 0.08);
    --radius-card: 1rem;
    --radius-table: 0.75rem;
}

/* ---------- Stats Cards ---------- */
.stats-row {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.25rem;
    margin-bottom: 2rem;
}

.stat-card-mini {
    background: white;
    border-radius: var(--radius-card);
    padding: 1.25rem 1.5rem;
    box-shadow: var(--shadow-sm);
    border: 1px solid var(--border-light);
    display: flex;
    align-items: center;
    justify-content: space-between;
    transition: all 0.2s ease;
}

.stat-card-mini:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
    border-color: var(--primary-lighter);
}

.stat-card-mini .stat-info .stat-number {
    font-size: 2rem;
    font-weight: 700;
    color: var(--primary-dark);
    line-height: 1.2;
}

.stat-card-mini .stat-info .stat-label {
    font-size: 0.7rem;
    color: var(--text-muted);
    margin-top: 4px;
    text-transform: uppercase;
    letter-spacing: 0.6px;
    font-weight: 500;
}

.stat-card-mini .stat-icon-circle {
    width: 48px;
    height: 48px;
    border-radius: 14px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--primary-lighter);
    transition: all 0.2s ease;
}

.stat-card-mini:hover .stat-icon-circle {
    background: var(--primary-dark);
}

.stat-card-mini:hover .stat-icon-circle svg {
    stroke: white;
}

.stat-card-mini .stat-icon-circle svg {
    stroke: var(--primary-dark);
    transition: stroke 0.2s ease;
}

/* ---------- Tabs Personalizados ---------- */
.nav-tabs-custom {
    display: flex;
    gap: 0.25rem;
    border-bottom: 1px solid var(--border-light);
    margin-bottom: 0;
    background: white;
    padding: 0;
}

.nav-tabs-custom .nav-link {
    border: none;
    padding: 0.75rem 1.5rem;
    color: var(--text-muted);
    font-weight: 500;
    font-size: 0.85rem;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    border-radius: 0;
    background: transparent;
    transition: all 0.2s ease;
    position: relative;
}

.nav-tabs-custom .nav-link:hover {
    color: var(--primary-dark);
    background: var(--primary-lighter);
}

.nav-tabs-custom .nav-link.active {
    color: var(--primary-dark);
    font-weight: 600;
    background: transparent;
}

.nav-tabs-custom .nav-link.active::after {
    content: '';
    position: absolute;
    bottom: -1px;
    left: 0;
    right: 0;
    height: 2px;
    background: var(--primary-dark);
    border-radius: 2px 2px 0 0;
}

.nav-tabs-custom .nav-link svg {
    stroke: currentColor;
    width: 18px;
    height: 18px;
}

/* ---------- Barra de cada tab ---------- */
.tab-header-bar {
    background: white;
    border: 1px solid var(--border-light);
    border-top: none;
    padding: 0.75rem 1rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.75rem;
}

/* ---------- Contenedor de tabla ---------- */
.table-container {
    background: white;
    border-radius: 0 0 var(--radius-table) var(--radius-table);
    border: 1px solid var(--border-light);
    border-top: none;
    overflow-x: auto;
    box-shadow: var(--shadow-sm);
}

.table {
    margin-bottom: 0;
    font-size: 0.85rem;
}

.table thead th {
    background: var(--gray-bg);
    color: var(--primary-dark);
    font-weight: 600;
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.6px;
    border-bottom: 2px solid var(--primary-dark);
    padding: 0.9rem 0.75rem;
}

.table tbody td {
    vertical-align: middle;
    padding: 0.85rem 0.75rem;
    border-bottom: 1px solid var(--border-light);
}

.table-hover tbody tr:hover {
    background-color: var(--primary-lighter);
    transition: background 0.15s ease;
}

/* ---------- Badges ---------- */
.badge-activo {
    background: #e8f5e9;
    color: var(--success);
    border: none;
    font-size: 0.7rem;
    font-weight: 500;
    padding: 0.25rem 0.7rem;
    border-radius: 20px;
    display: inline-flex;
    align-items: center;
    gap: 4px;
}

.badge-inactivo {
    background: #ffebee;
    color: var(--danger);
    border: none;
    font-size: 0.7rem;
    font-weight: 500;
    padding: 0.25rem 0.7rem;
    border-radius: 20px;
    display: inline-flex;
    align-items: center;
    gap: 4px;
}

/* Badges en el árbol - raíz (fondo oscuro) */
.arbol-raiz > .arbol-nodo-header .badge-activo {
    background: rgba(255, 255, 255, 0.2);
    color: white;
}

.arbol-raiz > .arbol-nodo-header .badge-inactivo {
    background: rgba(255, 255, 255, 0.2);
    color: #ffcdd2;
}

/* ---------- Botones ---------- */
.btn-primary-dark {
    background: var(--primary-dark);
    border-color: var(--primary-dark);
    color: white;
    font-weight: 500;
    padding: 0.4rem 1rem;
    border-radius: 8px;
    font-size: 0.8rem;
    transition: all 0.2s ease;
}

.btn-primary-dark:hover {
    background: var(--primary-light);
    border-color: var(--primary-light);
    color: white;
    transform: translateY(-1px);
}

.btn-outline-primary-dark {
    background: transparent;
    border: 1px solid var(--primary-dark);
    color: var(--primary-dark);
    font-weight: 500;
    padding: 0.4rem 1rem;
    border-radius: 8px;
    font-size: 0.8rem;
    transition: all 0.2s ease;
}

.btn-outline-primary-dark:hover {
    background: var(--primary-dark);
    color: white;
    transform: translateY(-1px);
}

.btn-action {
    padding: 0.3rem 0.6rem;
    font-size: 0.7rem;
    border-radius: 6px;
    transition: all 0.15s ease;
}

.btn-action:hover {
    transform: scale(1.02);
}

/* ---------- Modales ---------- */
.modal-content {
    border-radius: 1rem;
    border: none;
    overflow: hidden;
    box-shadow: 0 20px 35px -10px rgba(0, 0, 0, 0.2);
}

.modal-header {
    background: var(--primary-dark);
    color: white;
    padding: 1rem 1.5rem;
    border-bottom: none;
}

.modal-header .btn-close {
    filter: brightness(0) invert(1);
    opacity: 0.8;
    transition: opacity 0.2s;
}

.modal-header .btn-close:hover {
    opacity: 1;
}

.modal-title {
    font-weight: 600;
    font-size: 1.1rem;
}

.modal-body {
    padding: 1.5rem;
}

.modal-footer {
    border-top: 1px solid var(--border-light);
    padding: 1rem 1.5rem;
    background: var(--gray-bg);
}

/* ---------- Formularios ---------- */
.form-label {
    font-weight: 500;
    font-size: 0.8rem;
    color: var(--primary-dark);
    margin-bottom: 0.3rem;
}

.form-control, .form-select {
    border-radius: 8px;
    border: 1px solid var(--border-light);
    padding: 0.5rem 0.75rem;
    font-size: 0.85rem;
    transition: all 0.2s ease;
}

.form-control:focus, .form-select:focus {
    border-color: var(--primary-dark);
    box-shadow: 0 0 0 3px rgba(30, 60, 114, 0.15);
}

.form-control.is-valid {
    border-color: var(--success);
    background-image: none;
}

.form-control.is-invalid {
    border-color: var(--danger);
    background-image: none;
}

.valid-feedback, .invalid-feedback {
    font-size: 0.7rem;
    margin-top: 0.25rem;
}

/* ---------- Detalle Enriquecido ---------- */
.detail-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1.25rem;
    padding-bottom: 0.75rem;
    border-bottom: 2px solid var(--border-light);
}

.detail-header h5 {
    margin: 0;
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--primary-dark);
}

.detail-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.75rem;
    margin-bottom: 1rem;
}

.detail-item {
    padding: 0.5rem 0;
}

.detail-item .detail-label {
    font-size: 0.65rem;
    text-transform: uppercase;
    color: var(--text-muted);
    letter-spacing: 0.8px;
    font-weight: 600;
}

.detail-item .detail-value {
    font-weight: 500;
    color: #1a1a1a;
    font-size: 0.9rem;
}

.detail-section {
    margin-top: 1.25rem;
    padding-top: 1rem;
    border-top: 1px solid var(--border-light);
}

.detail-section-title {
    color: var(--primary-dark);
    font-weight: 600;
    font-size: 0.85rem;
    margin-bottom: 0.75rem;
    display: flex;
    align-items: center;
    gap: 8px;
}

.detail-section-title .badge-count {
    background: var(--primary-dark);
    color: white;
    border-radius: 20px;
    padding: 0.15rem 0.5rem;
    font-size: 0.65rem;
    font-weight: 600;
}

.detail-list {
    list-style: none;
    padding: 0;
    margin: 0;
}

.detail-list-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.6rem 0.8rem;
    border-radius: 8px;
    margin-bottom: 0.25rem;
    background: var(--gray-bg);
    transition: background 0.2s ease;
}

.detail-list-item:hover {
    background: var(--primary-lighter);
}

.detail-list-item .item-info {
    display: flex;
    flex-direction: column;
}

.detail-list-item .item-name {
    font-weight: 500;
    color: var(--primary-dark);
    font-size: 0.85rem;
}

.detail-list-item .item-sub {
    font-size: 0.7rem;
    color: var(--text-muted);
}

.detail-list-item .btn-item-action {
    padding: 0.2rem 0.5rem;
    font-size: 0.65rem;
    border-radius: 6px;
    background: white;
    border: 1px solid var(--border-light);
    color: var(--primary-dark);
    cursor: pointer;
    transition: all 0.2s ease;
}

.detail-list-item .btn-item-action:hover {
    background: var(--primary-dark);
    color: white;
    border-color: var(--primary-dark);
}

.detail-empty {
    text-align: center;
    padding: 1rem;
    color: var(--text-muted);
    font-size: 0.8rem;
    font-style: italic;
}

.detail-actions-bar {
    display: flex;
    gap: 0.5rem;
    margin-top: 1.25rem;
    padding-top: 1rem;
    border-top: 1px solid var(--border-light);
}

/* ---------- Loading Spinner ---------- */
.loading-spinner {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem;
    gap: 8px;
    color: var(--text-muted);
    font-size: 0.85rem;
}

.spinner-icon {
    animation: spin 0.8s linear infinite;
    width: 18px;
    height: 18px;
}

@keyframes spin {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
}

/* ---------- Highlight de búsqueda ---------- */
.highlight {
    background: #fff3cd;
    padding: 0 2px;
    border-radius: 3px;
    font-weight: 600;
}

/* ---------- Toast Notifications ---------- */
@keyframes slideInRight {
    from { transform: translateX(100%); opacity: 0; }
    to { transform: translateX(0); opacity: 1; }
}

@keyframes slideOutRight {
    from { transform: translateX(0); opacity: 1; }
    to { transform: translateX(100%); opacity: 0; }
}

/* ---------- Árbol Jerárquico ---------- */
.arbol-container {
    padding: 0.5rem;
}

.arbol-nodo {
    margin-bottom: 0.25rem;
}

.arbol-nodo-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.6rem 0.8rem;
    border-radius: 8px;
    cursor: pointer;
    transition: all 0.2s ease;
    background: white;
    border: 1px solid var(--border-light);
}

.arbol-nodo-header:hover {
    background: var(--gray-bg);
    border-color: var(--primary-lighter);
}

/* Raíz - Institución */
.arbol-raiz > .arbol-nodo-header {
    background: var(--primary-dark);
    color: white;
    border: none;
    font-weight: 500;
}

.arbol-raiz > .arbol-nodo-header:hover {
    background: var(--primary-light);
}

.arbol-raiz > .arbol-nodo-header .arbol-toggle,
.arbol-raiz > .arbol-nodo-header .arbol-icon svg {
    color: white;
    stroke: white;
}

.arbol-raiz > .arbol-nodo-header .arbol-nombre {
    color: white;
}

/* Rama - Departamento */
.arbol-rama > .arbol-nodo-header {
    background: var(--primary-lighter);
    border-left: 3px solid var(--primary-dark);
}

/* Rama directa de responsables */
.arbol-rama-directa > .arbol-nodo-header {
    background: #f5f5f5;
    border: 1px dashed var(--border-light);
    font-style: normal;
}

/* Hoja - Responsable */
.arbol-hoja > .arbol-nodo-header {
    background: white;
    border-left: 2px solid #ddd;
}

.arbol-hoja > .arbol-nodo-header:hover {
    background: var(--gray-bg);
}

.arbol-toggle {
    font-size: 0.7rem;
    transition: transform 0.25s ease;
    color: var(--primary-dark);
    width: 18px;
    text-align: center;
    font-weight: bold;
}

.arbol-toggle.collapsed {
    transform: rotate(-90deg);
}

.arbol-icon svg {
    stroke: var(--primary-dark);
    width: 16px;
    height: 16px;
}

.arbol-nombre {
    font-weight: 500;
    color: var(--primary-dark);
    flex: 1;
    font-size: 0.85rem;
}

.arbol-sub {
    font-size: 0.7rem;
    color: var(--text-muted);
    margin-left: 0.25rem;
}

.arbol-badge {
    font-size: 0.65rem;
    margin-left: 0.25rem;
}

.arbol-acciones {
    display: flex;
    gap: 0.25rem;
    opacity: 0;
    transition: opacity 0.2s ease;
}

.arbol-nodo-header:hover .arbol-acciones {
    opacity: 1;
}

.arbol-hijos {
    margin-left: 1.5rem;
    padding-left: 0.75rem;
    border-left: 2px solid var(--border-light);
    overflow: hidden;
    transition: max-height 0.3s ease, opacity 0.25s ease, padding 0.2s;
    max-height: 2000px;
    opacity: 1;
}

.arbol-hijos.collapsed {
    max-height: 0;
    opacity: 0;
    padding-left: 0;
    border-left-color: transparent;
    margin-left: 0;
}

/* ---------- Eliminar Modal ---------- */
.delete-warning {
    background: #fff3f3;
    border: 1px solid #ffcdd2;
    border-radius: 10px;
    padding: 0.75rem;
    margin-bottom: 1rem;
    font-size: 0.8rem;
    color: var(--danger);
}

/* ---------- Responsive ---------- */
@media (max-width: 992px) {
    .stats-row {
        grid-template-columns: repeat(2, 1fr);
        gap: 1rem;
    }
    
    .detail-grid {
        grid-template-columns: 1fr;
    }
}

@media (max-width: 768px) {
    .nav-tabs-custom .nav-link {
        padding: 0.5rem 1rem;
        font-size: 0.75rem;
    }
    
    .tab-header-bar {
        flex-direction: column;
        align-items: stretch;
    }
    
    .tab-header-bar .d-flex {
        justify-content: space-between;
    }
    
    .modal-body {
        padding: 1rem;
    }
}

@media (max-width: 576px) {
    .stats-row {
        grid-template-columns: 1fr;
    }
    
    .table thead {
        display: none;
    }
    
    .table tbody td {
        display: block;
        text-align: right;
        padding-left: 50%;
        position: relative;
    }
    
    .table tbody td::before {
        content: attr(data-label);
        position: absolute;
        left: 0.75rem;
        width: 45%;
        text-align: left;
        font-weight: 600;
        color: var(--primary-dark);
        font-size: 0.7rem;
    }
    
    .table tbody tr {
        margin-bottom: 1rem;
        display: block;
        border: 1px solid var(--border-light);
        border-radius: 8px;
    }
    
    .table tbody td:last-child {
        border-bottom: none;
    }
    
    .arbol-hijos {
        margin-left: 0.75rem;
        padding-left: 0.5rem;
    }
    
    .arbol-nodo-header {
        flex-wrap: wrap;
        gap: 0.3rem;
    }
    
    .arbol-acciones {
        opacity: 1;
        margin-left: auto;
    }
}
