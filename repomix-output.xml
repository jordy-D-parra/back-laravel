<file path="resources/css/admin-solicitudes.css">
/* ============================================================
   ADMIN SOLICITUDES - Estilos minimalistas consistentes
   ============================================================ */

:root {
    --primary-dark: #1e3c72;
    --primary-light: #2a4a8a;
    --primary-lighter: #eef3fc;
    --border-light: #e9ecef;
    --text-muted: #6c757d;
    --shadow-sm: 0 2px 8px rgba(0, 0, 0, 0.05);
}

/* Tarjetas de estadísticas */
.stats-row {
    display: flex;
    gap: 1rem;
    margin-bottom: 1.5rem;
    flex-wrap: wrap;
}

.stat-card-mini {
    flex: 1;
    min-width: 180px;
    background: white;
    border-radius: 12px;
    padding: 1rem 1.25rem;
    box-shadow: var(--shadow-sm);
    border: 1px solid var(--border-light);
    display: flex;
    align-items: center;
    justify-content: space-between;
}

.stat-number {
    font-size: 1.8rem;
    font-weight: 700;
    color: var(--primary-dark);
    line-height: 1.2;
}

.stat-label {
    font-size: 0.7rem;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.5px;
}

.stat-icon-circle {
    width: 42px;
    height: 42px;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--primary-lighter);
}

.stat-icon-circle svg {
    stroke: var(--primary-dark);
    width: 20px;
    height: 20px;
}

/* Filtros simplificados */
.filters-bar {
    background: white;
    border-radius: 12px;
    padding: 0.75rem 1rem;
    margin-bottom: 1.5rem;
    box-shadow: var(--shadow-sm);
    border: 1px solid var(--border-light);
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    align-items: center;
}

.filters-bar .form-control,
.filters-bar .form-select {
    font-size: 0.8rem;
    padding: 0.35rem 0.6rem;
    border-radius: 6px;
    min-width: 130px;
}

.filters-bar .btn {
    padding: 0.35rem 0.8rem;
    font-size: 0.8rem;
}

/* Tabla */
.table-container {
    background: white;
    border-radius: 12px;
    box-shadow: var(--shadow-sm);
    border: 1px solid var(--border-light);
    overflow: hidden;
}

.table th {
    background: #f8f9fc;
    color: var(--primary-dark);
    font-weight: 600;
    font-size: 0.7rem;
    text-transform: uppercase;
    padding: 0.75rem 0.75rem;
    border-bottom: 2px solid var(--primary-dark);
}

.table td {
    padding: 0.7rem 0.75rem;
    font-size: 0.8rem;
    border-bottom: 1px solid var(--border-light);
}

.table tbody tr:hover {
    background-color: var(--primary-lighter);
}

/* Badges minimalistas */
.badge-estado {
    display: inline-block;
    padding: 3px 8px;
    border-radius: 12px;
    font-size: 0.65rem;
    font-weight: 600;
}

.badge-estado-pendiente { background: #fff3cd; color: #856404; }
.badge-estado-aprobada { background: #d4edda; color: #155724; }
.badge-estado-rechazada { background: #f8d7da; color: #721c24; }
.badge-estado-cancelada { background: #e2e3e5; color: #383d41; }

.badge-prioridad {
    display: inline-block;
    padding: 3px 8px;
    border-radius: 12px;
    font-size: 0.65rem;
    font-weight: 600;
}

.badge-prioridad-baja { background: #e9ecef; color: #6c757d; }
.badge-prioridad-normal { background: #d4edda; color: #155724; }
.badge-prioridad-alta { background: #fff3cd; color: #856404; }
.badge-prioridad-urgente { background: #f8d7da; color: #721c24; }

/* Botones */
.btn-primary-dark {
    background: var(--primary-dark);
    border: none;
    color: white;
    padding: 0.35rem 1rem;
    border-radius: 6px;
    font-size: 0.8rem;
}

.btn-primary-dark:hover {
    background: var(--primary-light);
    color: white;
}

.btn-outline-primary-dark {
    background: transparent;
    border: 1px solid var(--primary-dark);
    color: var(--primary-dark);
    padding: 0.35rem 1rem;
    border-radius: 6px;
    font-size: 0.8rem;
}

.btn-outline-primary-dark:hover {
    background: var(--primary-dark);
    color: white;
}

.btn-sm {
    padding: 0.25rem 0.5rem;
    font-size: 0.7rem;
}

/* Acciones en tabla */
.btn-accion {
    background: transparent;
    border: none;
    padding: 4px 8px;
    border-radius: 4px;
    cursor: pointer;
    font-size: 0.7rem;
}

.btn-ver { color: #17a2b8; }
.btn-ver:hover { background: #17a2b8; color: white; }

.btn-editar { color: #ffc107; }
.btn-editar:hover { background: #ffc107; color: #1e3c72; }

.btn-cancelar { color: #dc3545; }
.btn-cancelar:hover { background: #dc3545; color: white; }

/* Modales */
.modal-content {
    border-radius: 12px;
    border: none;
}

.modal-header {
    background: var(--primary-dark);
    color: white;
    padding: 0.75rem 1.25rem;
}

.modal-header .btn-close {
    filter: brightness(0) invert(1);
}

.modal-body {
    padding: 1.25rem;
    max-height: 70vh;
    overflow-y: auto;
}

.modal-footer {
    padding: 0.75rem 1.25rem;
    border-top: 1px solid var(--border-light);
}

/* Formularios */
.form-label {
    font-weight: 500;
    font-size: 0.75rem;
    color: var(--primary-dark);
    margin-bottom: 0.25rem;
}

.form-control, .form-select {
    border-radius: 6px;
    border: 1px solid var(--border-light);
    padding: 0.4rem 0.6rem;
    font-size: 0.8rem;
}

.form-control:focus, .form-select:focus {
    border-color: var(--primary-dark);
    box-shadow: 0 0 0 2px rgba(30, 60, 114, 0.1);
}

/* Items card */
.item-card {
    background: #f8f9fc;
    border: 1px solid var(--border-light);
    border-radius: 8px;
    padding: 0.75rem;
    margin-bottom: 0.5rem;
}

.responsable-display {
    background: #f8f9fc;
    border-radius: 6px;
    padding: 0.5rem;
    min-height: 60px;
    border: 1px solid var(--border-light);
}

/* Paginación */
.pagination .page-link {
    color: var(--primary-dark);
    font-size: 0.75rem;
    padding: 0.3rem 0.6rem;
}

.pagination .active .page-link {
    background: var(--primary-dark);
    border-color: var(--primary-dark);
    color: white;
}

/* Skeleton */
.skeleton-row {
    background: linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 50%, #f0f0f0 75%);
    background-size: 200% 100%;
    animation: loading 1.5s infinite;
    border-radius: 6px;
    height: 50px;
    margin-bottom: 8px;
}

@keyframes loading {
    0% { background-position: 200% 0; }
    100% { background-position: -200% 0; }
}

/* Responsive */
@media (max-width: 768px) {
    .stats-row { flex-direction: column; }
    .filters-bar { flex-direction: column; align-items: stretch; }
    .filters-bar .form-control,
    .filters-bar .form-select,
    .filters-bar .btn { width: 100%; }
    .table-container { overflow-x: auto; }
    .table { min-width: 700px; }
}
</file>

