                                        ${det.estado_salida ? 
                                            `<span class="badge ${det.estado_salida === 'funcionando' ? 'bg-success' : (det.estado_salida === 'reemplazado' ? 'bg-warning' : 'bg-danger')} text-white">
                                                Salida: ${escapeHtml(det.estado_salida)}
