                            Componentes Revisados (${f.detalles.length})
                        </h6>
                        <div class="row">
                            ${f.detalles.map(det => `
                                <div class="col-md-6 mb-2">
                                    <div class="border rounded p-2" style="background: #f8f9fc;">
